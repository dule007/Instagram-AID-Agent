# Kopirati u lokalni `.env` koji je ignoriran u Gitu. Ne unositi stvarne
# vrijednosti u ovu example datoteku.
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_REDIRECT_URI=http://127.0.0.1:7012/callback
META_GRAPH_VERSION=
EXPECTED_INSTAGRAM_USERNAME=autoinsightdata
# Opcionalno dodatno zaključavanje kada je poznat numerički IG User ID.
EXPECTED_IG_USER_ID=
META_INSTAGRAM_SCOPES=instagram_business_basic,instagram_business_content_publish,instagram_business_manage_insights
# Opcionalni izravni credential par; ne koristiti zajedno s različitim
# vrijednostima u IG_USER_ID / META_ACCESS_TOKEN.
INSTAGRAM_IG_USER_ID=
INSTAGRAM_ACCESS_TOKEN=
# Javni media host. Meta ne može povući sliku s lokalnog diska, pa finalni
# JPEG mora imati javni HTTPS URL. Token treba ovlast Contents: Read and write
# na navedenom repozitoriju, a repozitorij mora biti Public.
GITHUB_TOKEN=
GITHUB_MEDIA_REPO=dule007/Instagram-AID-Agent
GITHUB_MEDIA_BRANCH=main
GITHUB_MEDIA_DIR=media
